{
  "version": 2,
  "builds": [
    {
      "src": "index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/static/(.*)",
      "dest": "/static/$1",
      "headers": { "cache-control": "s-maxage=31536000, stale-while-revalidate" }
    },
    {
      "src": "/(.*)",
      "dest": "index.py"
    }
  ]
}